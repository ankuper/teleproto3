# Сгенерировать: head -c 16 /dev/urandom | xxd -p
SECRET=

# Публичный IP сервера (для NAT info → Telegram DC)
EXTERNAL_IP=

# PROXY_PROTOCOL: ожидать ли PROXY-заголовок от nginx?
# Важно: nginx http{} proxy_pass НЕ поддерживает отправку PROXY-заголовков бекенду.
# При использовании nginx-ws-location.conf.template оставьте false.
# true — только для кастомных nginx stream{} конфигураций.
PROXY_PROTOCOL=false
