      "id": "kdf-tag-eeeeeeee",
      "_note": "KDF KAT — synthesised (random_header, secret) pair where decrypted random_header[56..60) = 0xeeeeeeee (medium mode). Args carry random_header (64 bytes) and secret (16 bytes) hex-concatenated; runner derives keys per §4.2 and asserts the magic tag.",
      "args": [
        "TODO-KAT-RANDOM-HEADER-64-BYTES",
        "TODO-KAT-SECRET-16-BYTES"
      ],
      "expect": {
        "ok": true,
        "result": {
          "magic_tag": "eeeeeeee",
          "mode": "medium"
        }
      }
    },
    {
      "id": "kdf-tag-dddddddd",
      "_note": "KDF KAT — magic tag 0xdddddddd (medium+pad mode).",
      "args": [
        "TODO-KAT-RANDOM-HEADER-64-BYTES",
        "TODO-KAT-SECRET-16-BYTES"
      ],
      "expect": {
        "ok": true,
        "result": {
          "magic_tag": "dddddddd",
          "mode": "medium-pad"
        }
      }
    },
    {
      "id": "kdf-tag-efefefef",
      "_note": "KDF KAT — magic tag 0xefefefef (compact mode).",
      "args": [
        "TODO-KAT-RANDOM-HEADER-64-BYTES",
        "TODO-KAT-SECRET-16-BYTES"
      ],
      "expect": {
        "ok": true,
        "result": {
          "magic_tag": "efefefef",
          "mode": "compact"
        }
      }
    },
    {
      "id": "kdf-tag-mismatch",
      "_note": "KDF KAT — decrypted random_header[56..60) = 0xcafebabe (not in admission set); silent-close gate per §4.2.",
      "args": [
        "TODO-KAT-RANDOM-HEADER-64-BYTES",
        "TODO-KAT-SECRET-16-BYTES"
      ],
      "expect": {
        "ok": false,
        "error": "MALFORMED"
      }
    },
    {
      "id": "kdf-symmetry-roundtrip",
